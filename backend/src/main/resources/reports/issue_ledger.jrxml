<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
    http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
  name="issue_ledger"
  pageWidth="595" pageHeight="842"
  leftMargin="50" rightMargin="50" topMargin="50" bottomMargin="50"
  columnWidth="495">

  <parameter name="issueDate" class="java.lang.String"/>

  <field name="documentTypeName" class="java.lang.String"/>
  <field name="targetInfo" class="java.lang.String"/>
  <field name="issuePurpose" class="java.lang.String"/>
  <field name="issuedBy" class="java.lang.String"/>
  <field name="issuedAt" class="java.lang.String"/>

  <variable name="rowNumber" class="java.lang.Integer" resetType="Report" calculation="Count">
    <variableExpression><![CDATA[Boolean.TRUE]]></variableExpression>
  </variable>

  <title>
    <band height="80">
      <staticText>
        <reportElement x="0" y="20" width="495" height="40"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="16" isBold="true"/>
        </textElement>
        <text><![CDATA[전사망자 확인증 발급대장]]></text>
      </staticText>
    </band>
  </title>

  <columnHeader>
    <band height="25">
      <staticText>
        <reportElement x="0" y="0" width="30" height="25" mode="Opaque" backcolor="#DDDDDD"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8" isBold="true"/>
        </textElement>
        <text><![CDATA[번호]]></text>
      </staticText>
      <staticText>
        <reportElement x="30" y="0" width="100" height="25" mode="Opaque" backcolor="#DDDDDD"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8" isBold="true"/>
        </textElement>
        <text><![CDATA[문서유형]]></text>
      </staticText>
      <staticText>
        <reportElement x="130" y="0" width="70" height="25" mode="Opaque" backcolor="#DDDDDD"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8" isBold="true"/>
        </textElement>
        <text><![CDATA[대상자]]></text>
      </staticText>
      <staticText>
        <reportElement x="200" y="0" width="120" height="25" mode="Opaque" backcolor="#DDDDDD"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8" isBold="true"/>
        </textElement>
        <text><![CDATA[발급목적]]></text>
      </staticText>
      <staticText>
        <reportElement x="320" y="0" width="70" height="25" mode="Opaque" backcolor="#DDDDDD"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8" isBold="true"/>
        </textElement>
        <text><![CDATA[발급자]]></text>
      </staticText>
      <staticText>
        <reportElement x="390" y="0" width="105" height="25" mode="Opaque" backcolor="#DDDDDD"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8" isBold="true"/>
        </textElement>
        <text><![CDATA[발급일시]]></text>
      </staticText>
    </band>
  </columnHeader>

  <detail>
    <band height="20">
      <textField>
        <reportElement x="0" y="0" width="30" height="20"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$V{rowNumber}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="30" y="0" width="100" height="20"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{documentTypeName}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="130" y="0" width="70" height="20"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{targetInfo}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="200" y="0" width="120" height="20"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{issuePurpose}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="320" y="0" width="70" height="20"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{issuedBy}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="390" y="0" width="105" height="20"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{issuedAt}]]></textFieldExpression>
      </textField>
    </band>
  </detail>

  <pageFooter>
    <band height="30">
      <textField>
        <reportElement x="200" y="5" width="95" height="20"/>
        <textElement textAlignment="Right" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8"/>
        </textElement>
        <textFieldExpression><![CDATA[$V{PAGE_NUMBER} + " / "]]></textFieldExpression>
      </textField>
      <textField evaluationTime="Report">
        <reportElement x="295" y="5" width="50" height="20"/>
        <textElement verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8"/>
        </textElement>
        <textFieldExpression><![CDATA[$V{PAGE_NUMBER}]]></textFieldExpression>
      </textField>
    </band>
  </pageFooter>
</jasperReport>
