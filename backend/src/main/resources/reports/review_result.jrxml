<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
    http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
  name="review_result"
  pageWidth="595" pageHeight="842"
  leftMargin="50" rightMargin="50" topMargin="50" bottomMargin="50"
  columnWidth="495">

  <parameter name="name" class="java.lang.String"/>
  <parameter name="serviceNumber" class="java.lang.String"/>
  <parameter name="rankName" class="java.lang.String"/>
  <parameter name="reviewRound" class="java.lang.String"/>
  <parameter name="reviewDate" class="java.lang.String"/>
  <parameter name="classification" class="java.lang.String"/>
  <parameter name="unitReviewResult" class="java.lang.String"/>
  <parameter name="diseaseName" class="java.lang.String"/>
  <parameter name="issueDate" class="java.lang.String"/>

  <title>
    <band height="80">
      <staticText>
        <reportElement x="0" y="20" width="495" height="40"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="18" isBold="true"/>
        </textElement>
        <text><![CDATA[전공사상 심사 결과서]]></text>
      </staticText>
    </band>
  </title>

  <detail>
    <band height="400">
      <staticText>
        <reportElement x="0" y="20" width="100" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <text><![CDATA[성    명]]></text>
      </staticText>
      <textField>
        <reportElement x="100" y="20" width="150" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{name}]]></textFieldExpression>
      </textField>
      <staticText>
        <reportElement x="250" y="20" width="100" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <text><![CDATA[군    번]]></text>
      </staticText>
      <textField>
        <reportElement x="350" y="20" width="145" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{serviceNumber}]]></textFieldExpression>
      </textField>

      <staticText>
        <reportElement x="0" y="45" width="100" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <text><![CDATA[계    급]]></text>
      </staticText>
      <textField>
        <reportElement x="100" y="45" width="150" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{rankName}]]></textFieldExpression>
      </textField>
      <staticText>
        <reportElement x="250" y="45" width="100" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <text><![CDATA[심사차수]]></text>
      </staticText>
      <textField>
        <reportElement x="350" y="45" width="145" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{reviewRound}]]></textFieldExpression>
      </textField>

      <staticText>
        <reportElement x="0" y="70" width="100" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <text><![CDATA[심사일자]]></text>
      </staticText>
      <textField>
        <reportElement x="100" y="70" width="150" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{reviewDate}]]></textFieldExpression>
      </textField>
      <staticText>
        <reportElement x="250" y="70" width="100" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <text><![CDATA[병    명]]></text>
      </staticText>
      <textField>
        <reportElement x="350" y="70" width="145" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{diseaseName}]]></textFieldExpression>
      </textField>

      <staticText>
        <reportElement x="0" y="95" width="100" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <text><![CDATA[분류결과]]></text>
      </staticText>
      <textField>
        <reportElement x="100" y="95" width="150" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{classification}]]></textFieldExpression>
      </textField>
      <staticText>
        <reportElement x="250" y="95" width="100" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <text><![CDATA[부대심사]]></text>
      </staticText>
      <textField>
        <reportElement x="350" y="95" width="145" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{unitReviewResult}]]></textFieldExpression>
      </textField>

      <textField>
        <reportElement x="250" y="200" width="245" height="25"/>
        <textElement textAlignment="Right" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{issueDate}]]></textFieldExpression>
      </textField>

      <staticText>
        <reportElement x="100" y="250" width="295" height="30"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="14" isBold="true"/>
        </textElement>
        <text><![CDATA[해 군 본 부]]></text>
      </staticText>
    </band>
