<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
    http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
  name="wounded_certificate"
  pageWidth="595" pageHeight="842"
  leftMargin="50" rightMargin="50" topMargin="50" bottomMargin="50"
  columnWidth="495">

  <parameter name="name" class="java.lang.String"/>
  <parameter name="serviceNumber" class="java.lang.String"/>
  <parameter name="rankName" class="java.lang.String"/>
  <parameter name="birthDate" class="java.lang.String"/>
  <parameter name="diseaseName" class="java.lang.String"/>
  <parameter name="woundTypeName" class="java.lang.String"/>
  <parameter name="veteransOfficeName" class="java.lang.String"/>
  <parameter name="unitName" class="java.lang.String"/>
  <parameter name="issueDate" class="java.lang.String"/>

  <title>
    <band height="80">
      <staticText>
        <reportElement x="0" y="20" width="495" height="40"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="18" isBold="true"/>
        </textElement>
        <text><![CDATA[국가유공자 요건 해당사실 확인서]]></text>
      </staticText>
    </band>
  </title>

  <detail>
    <band height="450">
      <staticText>
        <reportElement x="0" y="20" width="100" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <text><![CDATA[성    명]]></text>
      </staticText>
      <textField>
        <reportElement x="100" y="20" width="150" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{name}]]></textFieldExpression>
      </textField>
      <staticText>
        <reportElement x="250" y="20" width="100" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <text><![CDATA[군    번]]></text>
      </staticText>
      <textField>
        <reportElement x="350" y="20" width="145" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{serviceNumber}]]></textFieldExpression>
      </textField>

      <staticText>
        <reportElement x="0" y="45" width="100" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <text><![CDATA[계    급]]></text>
      </staticText>
      <textField>
        <reportElement x="100" y="45" width="150" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{rankName}]]></textFieldExpression>
      </textField>
      <staticText>
        <reportElement x="250" y="45" width="100" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <text><![CDATA[생년월일]]></text>
      </staticText>
      <textField>
        <reportElement x="350" y="45" width="145" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{birthDate}]]></textFieldExpression>
      </textField>

      <staticText>
        <reportElement x="0" y="70" width="100" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <text><![CDATA[병    명]]></text>
      </staticText>
      <textField>
        <reportElement x="100" y="70" width="150" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{diseaseName}]]></textFieldExpression>
      </textField>
      <staticText>
