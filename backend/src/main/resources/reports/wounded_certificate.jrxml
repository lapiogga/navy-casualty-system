      <staticText>
        <reportElement x="0" y="185" width="495" height="60"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="12"/>
        </textElement>
        <text><![CDATA[위 사람은 국가유공자 등 예우 및 지원에 관한 법률 제4조의
요건에 해당하는 사실이 있음을 확인합니다.]]></text>
      </staticText>

      <textField>
        <reportElement x="250" y="280" width="245" height="25"/>
        <textElement textAlignment="Right" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{issueDate}]]></textFieldExpression>
      </textField>

      <staticText>
        <reportElement x="100" y="330" width="295" height="30"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="14" isBold="true"/>
        </textElement>
        <text><![CDATA[해 군 본 부]]></text>
