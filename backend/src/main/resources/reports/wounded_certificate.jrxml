        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <text><![CDATA[상이구분]]></text>
      </staticText>
      <textField>
        <reportElement x="350" y="70" width="145" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{woundTypeName}]]></textFieldExpression>
      </textField>

      <staticText>
        <reportElement x="0" y="95" width="100" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <text><![CDATA[보훈청명]]></text>
      </staticText>
      <textField>
        <reportElement x="100" y="95" width="395" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{veteransOfficeName}]]></textFieldExpression>
      </textField>

      <staticText>
        <reportElement x="0" y="120" width="100" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
        </textElement>
        <text><![CDATA[소속부대]]></text>
      </staticText>
      <textField>
        <reportElement x="100" y="120" width="395" height="25"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="11"/>
