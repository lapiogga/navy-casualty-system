<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
    http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
  name="wounded_status_report"
  pageWidth="595" pageHeight="842"
  leftMargin="50" rightMargin="50" topMargin="50" bottomMargin="50"
  columnWidth="495">

  <parameter name="issueDate" class="java.lang.String"/>

  <field name="serviceNumber" class="java.lang.String"/>
  <field name="name" class="java.lang.String"/>
  <field name="rankName" class="java.lang.String"/>
  <field name="unitName" class="java.lang.String"/>
  <field name="diseaseName" class="java.lang.String"/>
  <field name="woundTypeName" class="java.lang.String"/>
  <field name="veteransOfficeName" class="java.lang.String"/>

  <variable name="rowNumber" class="java.lang.Integer" resetType="Report" calculation="Count">
    <variableExpression><![CDATA[Boolean.TRUE]]></variableExpression>
  </variable>

  <title>
    <band height="80">
      <staticText>
        <reportElement x="0" y="20" width="495" height="40"/>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="16" isBold="true"/>
        </textElement>
        <text><![CDATA[상이자 현황 보고서]]></text>
      </staticText>
    </band>
  </title>

  <columnHeader>
    <band height="25">
      <staticText>
        <reportElement x="0" y="0" width="30" height="25" mode="Opaque" backcolor="#DDDDDD"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8" isBold="true"/>
        </textElement>
        <text><![CDATA[번호]]></text>
      </staticText>
      <staticText>
        <reportElement x="30" y="0" width="60" height="25" mode="Opaque" backcolor="#DDDDDD"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8" isBold="true"/>
        </textElement>
        <text><![CDATA[군번]]></text>
      </staticText>
      <staticText>
        <reportElement x="90" y="0" width="50" height="25" mode="Opaque" backcolor="#DDDDDD"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8" isBold="true"/>
        </textElement>
        <text><![CDATA[성명]]></text>
      </staticText>
      <staticText>
        <reportElement x="140" y="0" width="45" height="25" mode="Opaque" backcolor="#DDDDDD"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8" isBold="true"/>
        </textElement>
        <text><![CDATA[계급]]></text>
      </staticText>
      <staticText>
        <reportElement x="185" y="0" width="80" height="25" mode="Opaque" backcolor="#DDDDDD"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8" isBold="true"/>
        </textElement>
        <text><![CDATA[소속]]></text>
      </staticText>
      <staticText>
        <reportElement x="265" y="0" width="80" height="25" mode="Opaque" backcolor="#DDDDDD"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8" isBold="true"/>
        </textElement>
        <text><![CDATA[병명]]></text>
      </staticText>
      <staticText>
        <reportElement x="345" y="0" width="60" height="25" mode="Opaque" backcolor="#DDDDDD"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8" isBold="true"/>
        </textElement>
        <text><![CDATA[상이구분]]></text>
      </staticText>
      <staticText>
        <reportElement x="405" y="0" width="90" height="25" mode="Opaque" backcolor="#DDDDDD"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8" isBold="true"/>
        </textElement>
        <text><![CDATA[보훈청명]]></text>
      </staticText>
    </band>
  </columnHeader>

  <detail>
    <band height="20">
      <textField>
        <reportElement x="0" y="0" width="30" height="20"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$V{rowNumber}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="30" y="0" width="60" height="20"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{serviceNumber}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="90" y="0" width="50" height="20"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{name}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="140" y="0" width="45" height="20"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{rankName}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="185" y="0" width="80" height="20"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{unitName}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="265" y="0" width="80" height="20"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{diseaseName}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="345" y="0" width="60" height="20"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{woundTypeName}]]></textFieldExpression>
      </textField>
      <textField isBlankWhenNull="true">
        <reportElement x="405" y="0" width="90" height="20"/>
        <box><pen lineWidth="0.5"/></box>
        <textElement textAlignment="Center" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="7"/>
        </textElement>
        <textFieldExpression><![CDATA[$F{veteransOfficeName}]]></textFieldExpression>
      </textField>
    </band>
  </detail>

  <pageFooter>
    <band height="30">
      <textField>
        <reportElement x="200" y="5" width="95" height="20"/>
        <textElement textAlignment="Right" verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8"/>
        </textElement>
        <textFieldExpression><![CDATA[$V{PAGE_NUMBER} + " / "]]></textFieldExpression>
      </textField>
      <textField evaluationTime="Report">
        <reportElement x="295" y="5" width="50" height="20"/>
        <textElement verticalAlignment="Middle">
          <font fontName="NanumGothic" size="8"/>
        </textElement>
        <textFieldExpression><![CDATA[$V{PAGE_NUMBER}]]></textFieldExpression>
      </textField>
    </band>
  </pageFooter>
</jasperReport>
