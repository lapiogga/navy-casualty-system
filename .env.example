# 해군 사상자 관리 시스템 환경변수
# 이 파일을 .env로 복사 후 실제 값으로 변경하세요
# cp .env.example .env && vi .env

# 데이터베이스 (필수)
DB_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
DB_USERNAME=navy_user
DB_NAME=navy_casualty
DB_PORT=5432

# 애플리케이션 포트
APP_PORT=8080

# 주민번호 암호화 키 (필수, 32바이트 Base64)
PII_ENCRYPTION_KEY=CHANGE_ME_TO_BASE64_ENCODED_32BYTE_KEY

# Spring 프로파일
SPRING_PROFILE=prod

# TLS 설정 (선택 - deploy/generate-cert.sh 실행 후 설정)
# SERVER_SSL_ENABLED=true
# SSL_KEYSTORE_PASSWORD=CHANGE_ME
